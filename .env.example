# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info

# Database (local Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=rfpilot
DB_PASSWORD=rfpilot_dev_password
DB_DATABASE=rfpilot
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_READ_HOST=localhost
DB_READ_PORT=5432
DB_READ_USERNAME=rfpilot
DB_READ_PASSWORD=rfpilot_dev_password
DB_READ_DATABASE=rfpilot

# Redis (local Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# S3 / MinIO (local Docker)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=rfpilot-documents
S3_USE_PATH_STYLE=true
S3_CDN_URL=

# OpenAI (REQUIRED)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Document Extraction
TIKA_URL=http://localhost:9998
UNSTRUCTURED_API_KEY=

# Clerk Auth (REQUIRED)
CLERK_JWKS_URL=https://YOUR_FRONTEND_API.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://YOUR_FRONTEND_API.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_...

# Stripe (REQUIRED for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_IDS={"starter":"price_xxx","pro":"price_xxx","enterprise":"price_xxx"}

# Email (optional for dev)
SENDGRID_API_KEY=SG...
FROM_EMAIL=noreply@rfpilot.io

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=30000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Prometheus metrics — secure with a token in production
PROMETHEUS_METRICS=true
METRICS_TOKEN=change-me-in-production

# Encryption key for TOTP (64 hex chars — generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# Feature flags (comma-separated)
FEATURE_FLAGS=caching,auto_upsell,read_replica,cdn,advanced_compliance,usage_alerts,multi_llm_routing,sam_gov

# Admin Super-Admin
ADMIN_JWT_SECRET=admin-super-secret-change-me
ADMIN_SESSION_TIMEOUT=3600000
ADMIN_TOTP_ISSUER=RFPilot

# Growth & Referrals
REFERRAL_CREDIT_AMOUNT=50
TRIAL_LENGTH_DAYS=14

# PostHog Analytics
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# SAM.gov (for auto-import)
SAM_GOV_API_KEY=
SAM_GOV_BASE_URL=https://api.sam.gov/opportunities/v2

# Sentry
SENTRY_DSN=
